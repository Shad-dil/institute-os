datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  OWNER
  STAFF
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(OWNER)
  instituteId  String
  createdAt    DateTime @default(now())

  institute Institute @relation(fields: [instituteId], references: [id], onDelete: Cascade)
}

// 🏢 INSTITUTE / TENANT (Prepared for scaling to multi-tenancy later)
model Institute {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  createdAt DateTime @default(now())

  // Relations
  courses  Course[]
  students Student[]
  tests    Test[]
  batches  Batch[]
  users    User[]
  notifications Notification[]
  inquiries Inquiry[]
  feeReminderNotices FeeReminderNotice[]
}
enum NotificationType {
  PAYMENT_RECEIVED
  FEE_OVERDUE
  NEW_ADMISSION
  ATTENDANCE_RISK
  GENERAL
}

model Notification {
  id          String           @id @default(cuid())
  instituteId String
  type        NotificationType
  title       String
  message     String
  link        String?          // e.g. "/students/abc123" — where clicking it should go
  isRead      Boolean          @default(false)
  // Uniquely identifies WHAT this notification is about, e.g.
  // "fee-overdue-<invoiceId>" or "attrition-risk-<studentId>-<weekStart>".
  // Computed notifications (overdue fees, attendance risk) check for an
  // existing row with this key before creating a new one — this is what
  // stops a daily cron job from re-notifying about the same overdue
  // invoice every single day.
  dedupKey    String?          @unique
  createdAt   DateTime         @default(now())

  institute Institute @relation(fields: [instituteId], references: [id], onDelete: Cascade)

  @@index([instituteId, isRead, createdAt])
}

// 📚 COURSES offered by the institute
model Course {
  id          String   @id @default(cuid())
  name        String // e.g., "Python Programming", "Class 10 Math"
  fees        Decimal // Total course cost or monthly base fee
  duration    String // e.g., "3 Months", "1 Year"
  instituteId String
  createdAt   DateTime @default(now())
  billingCycle BillingCycle @default(ONE_TIME)

  // Relations
  institute Institute @relation(fields: [instituteId], references: [id], onDelete: Cascade)
  students  Student[]
  tests     Test[]
  batches   Batch[]
  inquiries Inquiry[]
}

// 👥 STUDENTS enrolled in the institute
model Student {
  id          String   @id @default(cuid())
  name        String
  email       String?
  phone       String // Crucial for sending WhatsApp/SMS updates
  photoUrl    String?
  parentName  String?
  parentPhone String?
  joinedAt    DateTime @default(now())
  instituteId String
  courseId    String

  enrollmentStatus EnrollmentStatus @default(ACTIVE)
  // Relations
  institute   Institute    @relation(fields: [instituteId], references: [id], onDelete: Cascade)
  course      Course       @relation(fields: [courseId], references: [id])
  attendance  Attendance[]
  invoices    Invoice[]
  testResults TestResult[]
  note        Note[]
  batchId     String?
  batch       Batch?       @relation(fields: [batchId], references: [id], onDelete: SetNull)
  inquiries Inquiry[]
}

model Note {
  id        String   @id @default(cuid())
  content   String
  studentId String
  createdAt DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

// 📅 ATTENDANCE TRACKER
model Attendance {
  id        String           @id @default(cuid())
  date      DateTime // Typically stored as just the date component (YYYY-MM-DD)
  status    AttendanceStatus // Custom Enum: PRESENT, ABSENT, LATE
  studentId String
  createdAt DateTime         @default(now())

  // Relations
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  // Ensure a student can only have one attendance record per day
  @@unique([studentId, date])
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
}

// 💰 FEE TRACKING & INVOICES

enum InvoiceStatus {
  PAID
  PARTIAL
  PENDING
  OVERDUE
}

// CHANGE: Invoice gets an amountPaid running total + a payments relation
model Invoice {
  id         String        @id @default(cuid())
  amount     Decimal
  amountPaid Decimal       @default(0) // NEW — running total across all payments
  dueDate    DateTime
  paidAt     DateTime? // now means "date of most recent payment", not just full payment
  status     InvoiceStatus @default(PENDING)
  studentId  String
  createdAt  DateTime      @default(now())

  student  Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  payments Payment[] // NEW
  feeReminderNotices FeeReminderNotice[]
}

// NEW MODEL — one row per actual payment collected. This is what makes
// partial payments, payment history, and receipts all possible: each
// receipt is just one Payment row rendered as a slip.
model Payment {
  id        String        @id @default(cuid())
  invoiceId String
  amount    Decimal
  method    PaymentMethod @default(CASH)
  paidAt    DateTime      @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

enum PaymentMethod {
  CASH
  UPI
  CARD
  BANK_TRANSFER
  OTHER
}

model Test {
  id          String   @id @default(cuid())
  name        String // e.g., "Physics Unit Test 3", "Tally Module 2 Exam"
  maxMarks    Decimal
  testDate    DateTime
  courseId    String
  instituteId String
  createdAt   DateTime @default(now())

  course    Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  institute Institute    @relation(fields: [instituteId], references: [id], onDelete: Cascade)
  results   TestResult[]
}

model TestResult {
  id            String   @id @default(cuid())
  testId        String
  studentId     String
  marksObtained Decimal
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  test    Test    @relation(fields: [testId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  // One result per student per test — re-entering marks updates this row
  // instead of creating a duplicate.
  @@unique([testId, studentId])
}

model Batch {
  id          String    @id @default(cuid())
  name        String // e.g., "Morning Batch A", "Evening — Weekdays"
  schedule    String // e.g., "Mon, Wed, Fri · 6:00–7:30 PM" — free text, not structured
  facultyName String? // plain text for now — becomes a real Teacher relation once that model exists
  capacity    Int?
  startDate   DateTime?
  courseId    String
  instituteId String
  createdAt   DateTime  @default(now())

  course    Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  institute Institute @relation(fields: [instituteId], references: [id], onDelete: Cascade)
  students  Student[]
}

enum InquiryStatus {
  NEW
  CONTACTED
  INTERESTED
  NOT_INTERESTED
  CONVERTED
  LOST
}

enum InquirySource {
  WALK_IN
  PHONE_CALL
  WHATSAPP
  REFERRAL
  SOCIAL_MEDIA
  OTHER
}

model Inquiry {
  id             String        @id @default(cuid())
  name           String
  phone          String
  courseId       String?       // nullable — a lead might be undecided which course yet
  source         InquirySource @default(WALK_IN)
  status         InquiryStatus @default(NEW)
  referredByName String?       // free text — "who sent them to you." Simple on
                                // purpose; linking to an actual Student record
                                // as the referrer is a natural v2, not needed
                                // to get value from this now.
  nextFollowUpAt DateTime?
  instituteId    String
  createdAt      DateTime      @default(now())

  // Set once this inquiry actually becomes a student — this single field
  // is what turns "a list of leads" into an actual measurable funnel.
  convertedStudentId String?  @unique

  institute        Institute         @relation(fields: [instituteId], references: [id], onDelete: Cascade)
  course           Course?           @relation(fields: [courseId], references: [id], onDelete: SetNull)
  convertedStudent Student?          @relation(fields: [convertedStudentId], references: [id], onDelete: SetNull)
  followUps        InquiryFollowUp[]
}

// A running history of contact attempts — "called, no answer," "said
// they'll decide after Diwali" — same pattern as Student's Note model,
// because the underlying need (a timestamped log a staff member can add
// to) is identical.
model InquiryFollowUp {
  id        String   @id @default(cuid())
  inquiryId String
  note      String
  createdAt DateTime @default(now())

  inquiry Inquiry @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
}
enum BillingCycle {
  ONE_TIME // computer institute style — one fee for the whole course
  MONTHLY  // coaching style — recurring, same amount, new invoice each month
}

enum EnrollmentStatus {
  ACTIVE
  PAUSED
  LEFT
}
model FeeReminderNotice {
  id          String   @id @default(cuid())
  instituteId String
  invoiceId   String   @unique
  studentName String   // denormalized so the banner can render without an extra join
  amount      Decimal
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  institute Institute @relation(fields: [instituteId], references: [id], onDelete: Cascade)
  invoice   Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}